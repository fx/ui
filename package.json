{
  "name": "@fx/ui",
  "version": "0.0.0",
  "type": "module",
  "private": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles/globals.css": "./dist/styles/globals.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fx/ui.git"
  },
  "scripts": {
    "build": "vite build && mkdir -p dist/styles && cp src/styles/globals.css dist/styles/globals.css",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "class-variance-authority": "^0.7",
    "clsx": "^2.1",
    "tailwind-merge": "^3.4",
    "lucide-react": "^0.563",
    "recharts": "^3.7",
    "date-fns": "^4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@storybook/react": "10.2.13",
    "@storybook/react-vite": "10.2.13",
    "@tailwindcss/vite": "^4",
    "@testing-library/jest-dom": "^6.9",
    "@testing-library/react": "^16",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4",
    "husky": "^9",
    "jsdom": "^27",
    "lint-staged": "^16",
    "react": "^19",
    "react-dom": "^19",
    "storybook": "10.2.13",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4",
    "typescript": "^5.7",
    "vite": "^7",
    "vite-plugin-dts": "^4",
    "vitest": "^3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
